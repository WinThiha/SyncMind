APP_NAME=SyncMind
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=syncmind
DB_USERNAME=syncmind
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=localhost:3000

CACHE_STORE=database
QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=hello@syncmind.local
MAIL_PASSWORD="your-email-password"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@syncmind.local"
MAIL_FROM_NAME="${APP_NAME}"

# Google OAuth — get credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# AI / LLM — uses OpenRouter by default (openrouter.ai/keys)
# Set AI_BASE_URL to any OpenAI-compatible endpoint (e.g. openrouter.ai/api/v1)
AI_API_KEY=your-openrouter-or-openai-key
AI_BASE_URL=openrouter.ai/api/v1
AI_MODEL=meta-llama/llama-3.1-8b-instruct:free
AI_CHAT_PROVIDER=openrouter
AI_CHAT_API_KEY=your-openrouter-or-openai-key
AI_CHAT_BASE_URL=https://openrouter.ai/api/v1
AI_CHAT_MODEL=meta-llama/llama-3.1-8b-instruct:free

# AI Embeddings (OpenAI-compatible) — dedicated provider lane
# New keys below are preferred. If omitted, backend falls back to AI_API_KEY/AI_BASE_URL/AI_MODEL.
AI_EMBEDDING_API_KEY=your-embedding-provider-key
AI_EMBEDDING_BASE_URL=https://api.openai.com/v1
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=768

# Docker user mapping — set to your host UID/GID (run `id -u` and `id -g`)
PUID=1000
PGID=1000
